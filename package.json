{
  "name": "bevtek",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter @bevtek/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:apply": "tsx scripts/apply-migration.ts",
    "db:apply:all": "tsx scripts/apply-migration.ts --all",
    "db:dry-run": "tsx scripts/apply-migration.ts --all --dry-run",
    "db:rls-check": "tsx scripts/check-rls.ts",
    "test:shared": "tsx scripts/test-shared-libs.ts",
    "eval:gabby": "tsx scripts/eval-gabby.ts",
    "enrich:metadata": "tsx scripts/enrich-inventory-metadata.ts",
    "enrich:metadata:dry": "tsx scripts/enrich-inventory-metadata.ts --limit=20",
    "enrich:metadata:analyze": "tsx scripts/enrich-inventory-metadata.ts --analyze-only",
    "audit:inventory": "tsx scripts/archive/audit-inventory-columns.ts",
    "inventory:stats": "tsx scripts/inventory-stats.ts",
    "image:coverage": "tsx scripts/image-coverage.ts",
    "image:promote": "tsx scripts/promote-inventory-images.ts",
    "image:promote:analyze": "tsx scripts/promote-inventory-images.ts --analyze-only",
    "image:clean": "tsx scripts/clean-inventory-images.ts",
    "google-images": "tsx scripts/fetch-google-images.ts",
    "google-images:test": "tsx scripts/fetch-google-images.ts --limit=10 --verbose",
    "off-images": "tsx scripts/fetch-openfoodfacts-images.ts",
    "off-images:test": "tsx scripts/fetch-openfoodfacts-images.ts --limit=10 --verbose",
    "off-images:beer": "tsx scripts/fetch-openfoodfacts-images.ts --category=beer --write",
    "wiki-images": "tsx scripts/fetch-wikipedia-images.ts",
    "wiki-images:test": "tsx scripts/fetch-wikipedia-images.ts --limit=10 --verbose",
    "wiki-images:spirits": "tsx scripts/fetch-wikipedia-images.ts --category=spirits --write",
    "scrape:gng": "tsx scripts/archive/scrape-grapes-and-grains.ts",
    "scrape:gng:test": "tsx scripts/archive/scrape-grapes-and-grains.ts --limit=10 --verbose",
    "scrape:gng:index": "tsx scripts/archive/scrape-grapes-and-grains.ts --phase=index",
    "scrape:gng:write": "tsx scripts/archive/scrape-grapes-and-grains.ts --write",
    "scrape:lb": "tsx scripts/archive/scrape-liquor-barn.ts",
    "scrape:lb:test": "tsx scripts/archive/scrape-liquor-barn.ts --limit=10 --verbose",
    "scrape:lb:index": "tsx scripts/archive/scrape-liquor-barn.ts --phase=index",
    "scrape:lb:write": "tsx scripts/archive/scrape-liquor-barn.ts --write",
    "validate:enrichment": "tsx scripts/validate-enrichment.ts",
    "backfill:brand": "tsx scripts/backfill-brand.ts",
    "backfill:brand:dry": "tsx scripts/backfill-brand.ts --limit=50",
    "infer:category": "tsx scripts/infer-category.ts",
    "infer:category:analyze": "tsx scripts/infer-category.ts --analyze-only",
    "infer:category:dry": "tsx scripts/infer-category.ts --limit=50",
    "catalog:build": "tsx scripts/build-catalog-products.ts",
    "catalog:build:analyze": "tsx scripts/build-catalog-products.ts --analyze-only",
    "catalog:build:dry": "tsx scripts/build-catalog-products.ts --limit=200"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
