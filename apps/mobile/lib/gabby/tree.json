{
  "version": 1,
  "root": "home",
  "nodes": {
    "home": {
      "kind": "choice",
      "title": "What are you looking for today?",
      "subtitle": "I'll help you narrow it down in just a few taps.",
      "options": [
        { "label": "Wine",     "emoji": "🍷", "next": "wine_color" },
        { "label": "Spirits",  "emoji": "🥃", "next": "spirits_type" },
        { "label": "Beer",     "emoji": "🍺", "next": "beer_style" },
        { "label": "Mixers & Garnishes", "emoji": "🍋", "next": "mixers_type" },
        { "label": "Just browse everything", "emoji": "👀", "action": "recommend", "filters": {} }
      ]
    },

    "wine_color": {
      "kind": "choice",
      "title": "Red, white, or something bubbly?",
      "category": "wine",
      "options": [
        { "label": "Red",       "emoji": "🍷", "next": "wine_red_style",   "filters": { "category": "wine", "subcategory": "red" } },
        { "label": "White",     "emoji": "🥂", "next": "wine_white_body",  "filters": { "category": "wine", "subcategory": "white" } },
        { "label": "Rosé",      "emoji": "🌸", "action": "recommend",      "filters": { "category": "wine", "subcategory": "rose" } },
        { "label": "Sparkling", "emoji": "🍾", "action": "recommend",      "filters": { "category": "wine", "subcategory": "sparkling" } }
      ]
    },

    "wine_red_style": {
      "kind": "choice",
      "title": "What kind of red?",
      "subtitle": "Pick a style — or tap 'not sure' and I'll ask about flavor instead.",
      "category": "wine",
      "options": [
        { "label": "Cabernet",   "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["cabernet", "cabernet sauvignon"] } },
        { "label": "Merlot",     "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["merlot"] } },
        { "label": "Pinot Noir", "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["pinot noir"] } },
        { "label": "Malbec",     "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["malbec"] } },
        { "label": "Syrah / Shiraz", "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["syrah", "shiraz"] } },
        { "label": "Zinfandel",  "emoji": "🍷", "next": "wine_red_body", "filters": { "style_any": ["zinfandel"] } },
        { "label": "Not sure — ask by flavor", "emoji": "🤔", "next": "wine_red_flavor" }
      ]
    },

    "wine_red_flavor": {
      "kind": "choice",
      "title": "What kind of flavor do you enjoy?",
      "category": "wine",
      "options": [
        { "label": "Bold & fruity",    "emoji": "🍒", "next": "wine_red_body", "filters": { "flavor_any": ["fruity", "jammy", "bold"] } },
        { "label": "Smooth & oaky",    "emoji": "🪵", "next": "wine_red_body", "filters": { "flavor_any": ["oaky", "smooth", "vanilla"] } },
        { "label": "Earthy & spicy",   "emoji": "🌿", "next": "wine_red_body", "filters": { "flavor_any": ["earthy", "spicy", "peppery"] } },
        { "label": "Light & easy-going", "emoji": "🌸", "next": "wine_red_body", "filters": { "flavor_any": ["light", "floral", "easy"] } }
      ]
    },

    "wine_red_body": {
      "kind": "choice",
      "title": "How full-bodied?",
      "subtitle": "Light sips easy, full fills your mouth like a steak dinner.",
      "category": "wine",
      "options": [
        { "label": "Light",  "emoji": "🪶", "next": "wine_red_price", "filters": { "body": "light" } },
        { "label": "Medium", "emoji": "⚖️", "next": "wine_red_price", "filters": { "body": "medium" } },
        { "label": "Full",   "emoji": "🏋️", "next": "wine_red_price", "filters": { "body": "full" } },
        { "label": "No preference", "emoji": "🤷", "next": "wine_red_price" }
      ]
    },

    "wine_red_price": {
      "kind": "choice",
      "title": "Budget?",
      "category": "wine",
      "options": [
        { "label": "Under $20",  "emoji": "💵", "next": "wine_red_occasion", "filters": { "price_max": 20 } },
        { "label": "$20 – $40",  "emoji": "💰", "next": "wine_red_occasion", "filters": { "price_min": 20, "price_max": 40 } },
        { "label": "$40 – $80",  "emoji": "💎", "next": "wine_red_occasion", "filters": { "price_min": 40, "price_max": 80 } },
        { "label": "Splurge ($80+)", "emoji": "🎩", "next": "wine_red_occasion", "filters": { "price_min": 80 } },
        { "label": "No budget limit", "emoji": "🌊", "next": "wine_red_occasion" }
      ]
    },

    "wine_red_occasion": {
      "kind": "choice",
      "title": "What's the occasion?",
      "subtitle": "I'll flag options that fit.",
      "category": "wine",
      "options": [
        { "label": "Dinner pairing",  "emoji": "🍽️", "action": "recommend", "filters": { "intended_use_any": ["dinner", "pairing"] } },
        { "label": "Gift",            "emoji": "🎁", "action": "recommend", "filters": { "intended_use_any": ["gift"] } },
        { "label": "Party / gathering","emoji": "🎉", "action": "recommend", "filters": { "intended_use_any": ["party"] } },
        { "label": "Just for me",     "emoji": "🛋️", "action": "recommend", "filters": {} }
      ]
    },

    "wine_white_body": {
      "kind": "choice",
      "title": "Crisp or creamy?",
      "category": "wine",
      "options": [
        { "label": "Crisp & dry (Sauv Blanc, Pinot Grigio)", "emoji": "❄️", "action": "recommend", "filters": { "style_any": ["sauvignon blanc", "pinot grigio", "albarino"], "sweetness": "dry" } },
        { "label": "Rich & buttery (Chardonnay)",           "emoji": "🧈", "action": "recommend", "filters": { "style_any": ["chardonnay"], "body": "full" } },
        { "label": "Sweet & fruity (Riesling, Moscato)",    "emoji": "🍑", "action": "recommend", "filters": { "style_any": ["riesling", "moscato", "gewurztraminer"], "sweetness": "sweet" } },
        { "label": "Show me everything white",              "emoji": "🥂", "action": "recommend", "filters": {} }
      ]
    },

    "spirits_type": {
      "kind": "choice",
      "title": "Which spirit?",
      "category": "spirits",
      "options": [
        { "label": "Whiskey / Bourbon", "emoji": "🥃", "action": "recommend", "filters": { "category": "spirits", "style_any": ["whiskey", "bourbon", "rye", "scotch"] } },
        { "label": "Gin",               "emoji": "🍸", "next": "gin_style",      "filters": { "category": "spirits", "style_any": ["gin"] } },
        { "label": "Vodka",             "emoji": "❄️", "action": "recommend", "filters": { "category": "spirits", "style_any": ["vodka"] } },
        { "label": "Tequila / Mezcal",  "emoji": "🌵", "action": "recommend", "filters": { "category": "spirits", "style_any": ["tequila", "mezcal"] } },
        { "label": "Rum",               "emoji": "🏝️", "action": "recommend", "filters": { "category": "spirits", "style_any": ["rum"] } },
        { "label": "Something else",    "emoji": "🥃", "action": "recommend", "filters": { "category": "spirits" } }
      ]
    },

    "gin_style": {
      "kind": "choice",
      "title": "How do you like your gin?",
      "category": "spirits",
      "options": [
        { "label": "Classic / juniper-forward (London Dry)", "emoji": "🌲", "next": "gin_use", "filters": { "flavor_any": ["juniper", "classic", "london dry"] } },
        { "label": "Floral & citrus",                        "emoji": "🌸", "next": "gin_use", "filters": { "flavor_any": ["floral", "citrus", "botanical"] } },
        { "label": "Barrel-aged / rich",                     "emoji": "🛢️", "next": "gin_use", "filters": { "flavor_any": ["barrel", "oak", "aged"] } },
        { "label": "Surprise me",                            "emoji": "🎲", "next": "gin_use" }
      ]
    },

    "gin_use": {
      "kind": "choice",
      "title": "Sipping or mixing?",
      "category": "spirits",
      "options": [
        { "label": "Gin & tonic / cocktails", "emoji": "🍸", "action": "recommend", "filters": { "intended_use_any": ["cocktail", "mixer"] } },
        { "label": "Martini",                 "emoji": "🫒", "action": "recommend", "filters": { "intended_use_any": ["martini", "cocktail"] } },
        { "label": "Sipping neat",            "emoji": "🥃", "action": "recommend", "filters": { "intended_use_any": ["sipping"] } },
        { "label": "Any of the above",        "emoji": "🤷", "action": "recommend", "filters": {} }
      ]
    },

    "beer_style": {
      "kind": "choice",
      "title": "What kind of beer?",
      "category": "beer",
      "options": [
        { "label": "IPA / hoppy",        "emoji": "🌿", "next": "ipa_hop", "filters": { "category": "beer", "style_any": ["ipa", "pale ale"] } },
        { "label": "Lager / pilsner",    "emoji": "🍺", "action": "recommend", "filters": { "category": "beer", "style_any": ["lager", "pilsner"] } },
        { "label": "Stout / porter",     "emoji": "🖤", "action": "recommend", "filters": { "category": "beer", "style_any": ["stout", "porter"] } },
        { "label": "Wheat / hefeweizen", "emoji": "🌾", "action": "recommend", "filters": { "category": "beer", "style_any": ["wheat", "hefeweizen", "witbier"] } },
        { "label": "Sour / fruited",     "emoji": "🍋", "action": "recommend", "filters": { "category": "beer", "style_any": ["sour", "gose", "fruited"] } },
        { "label": "Show me local brews", "emoji": "📍", "action": "recommend", "filters": { "category": "beer", "is_local": true } }
      ]
    },

    "ipa_hop": {
      "kind": "choice",
      "title": "How hoppy?",
      "category": "beer",
      "options": [
        { "label": "Easy-going (session IPA)", "emoji": "🪶", "action": "recommend", "filters": { "hop_level": "low" } },
        { "label": "Balanced (West Coast)",    "emoji": "⚖️", "action": "recommend", "filters": { "hop_level": "med" } },
        { "label": "Big & juicy (hazy / DIPA)", "emoji": "🌊", "action": "recommend", "filters": { "hop_level": "high" } },
        { "label": "Surprise me",              "emoji": "🎲", "action": "recommend", "filters": {} }
      ]
    },

    "mixers_type": {
      "kind": "choice",
      "title": "What are you looking for?",
      "options": [
        { "label": "Tonic / soda",        "emoji": "🥤", "action": "recommend", "filters": { "category": "mixer", "style_any": ["tonic", "soda", "club soda"] } },
        { "label": "Bitters",             "emoji": "🌿", "action": "recommend", "filters": { "category": "mixer", "style_any": ["bitters"] } },
        { "label": "Garnishes (olives, cherries)", "emoji": "🍒", "action": "recommend", "filters": { "category": "garnish" } },
        { "label": "Juice / syrup",       "emoji": "🍋", "action": "recommend", "filters": { "category": "mixer", "style_any": ["juice", "syrup"] } },
        { "label": "Glassware / bar tools", "emoji": "🥂", "action": "recommend", "filters": { "category": "barware" } }
      ]
    }
  }
}
